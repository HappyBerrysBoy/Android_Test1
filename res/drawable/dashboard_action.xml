<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/primaryColor" />
            <stroke android:width="2dp" android:color="@color/primaryPressed" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/surfacePressed" />
            <stroke android:width="1dp" android:color="@color/accentColor" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/surfaceColor" />
            <stroke android:width="1dp" android:color="@color/dividerColor" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
