<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBackground"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="44dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="166dp"
            android:background="@drawable/dashboard_header"
            android:gravity="bottom"
            android:orientation="vertical"
            android:paddingLeft="22dp"
            android:paddingTop="34dp"
            android:paddingRight="22dp"
            android:paddingBottom="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mixedCalculationTitle"
                android:textColor="@color/headerText"
                android:textSize="25sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/mixedCalculationSubtitle"
                android:textColor="@color/headerSubText"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/mixedSelectionSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="16dp"
            android:layout_marginRight="18dp"
            android:background="@drawable/selection_summary"
            android:padding="16dp"
            android:textColor="@color/headerBackground"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="22dp"
            android:layout_marginTop="22dp"
            android:layout_marginRight="22dp"
            android:text="@string/mixedPalletSection"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/mixedChoosePalletsButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="18dp"
            android:background="@drawable/secondary_button"
            android:onClick="chooseMixedPallets"
            android:text="@string/mixedChoosePallets"
            android:textAllCaps="false"
            android:textColor="@color/primaryColor"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mixedEmptyPallets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="22dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="22dp"
            android:text="@string/mixedNoPallets"
            android:textColor="@color/textSecondary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/mixedPalletsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="18dp"
            android:orientation="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="22dp"
            android:layout_marginTop="22dp"
            android:layout_marginRight="22dp"
            android:text="@string/mixedBoxSection"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/mixedChooseBoxesButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="18dp"
            android:background="@drawable/secondary_button"
            android:onClick="chooseMixedBoxes"
            android:text="@string/mixedChooseBoxes"
            android:textAllCaps="false"
            android:textColor="@color/primaryColor"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mixedEmptyBoxes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="22dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="22dp"
            android:text="@string/mixedNoBoxes"
            android:textColor="@color/textSecondary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/mixedBoxesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="18dp"
            android:orientation="vertical" />

        <Button
            android:id="@+id/mixedCalculateButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="24dp"
            android:layout_marginRight="18dp"
            android:background="@drawable/primary_button"
            android:onClick="calculateMixedLoad"
            android:text="@string/mixedRunCalculation"
            android:textAllCaps="false"
            android:textColor="@color/headerText"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="18dp"
            android:background="@drawable/secondary_button"
            android:onClick="btnBack"
            android:text="@string/back_button"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary" />
    </LinearLayout>
</ScrollView>
