<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/modern_dialog_background"
    android:clipToOutline="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:background="@drawable/modern_dialog_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/confirmDeleteTitle"
                android:textColor="@color/headerText"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/confirmDeleteSubtitle"
                android:textColor="@color/headerSubText"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/confirmDialogClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/closeDialog"
            android:padding="13dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/headerText" />
    </LinearLayout>

    <TextView
        android:id="@+id/confirmDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="3dp"
        android:paddingLeft="22dp"
        android:paddingTop="24dp"
        android:paddingRight="22dp"
        android:paddingBottom="22dp"
        android:textColor="@color/textPrimary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <Button
            android:id="@+id/confirmDialogCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginRight="8dp"
            android:layout_weight="1"
            android:background="@drawable/secondary_button"
            android:text="@string/dialogCancel"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/confirmDialogConfirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/danger_action_button"
            android:textAllCaps="false"
            android:textColor="@color/headerText"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
