<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/modern_dialog_background"
    android:clipToOutline="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:background="@drawable/modern_dialog_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/multiChoiceDialogTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/headerText"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/multiChoiceDialogSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/mixedMultiSelectHint"
                android:textColor="@color/headerSubText"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/multiChoiceDialogClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/closeDialog"
            android:padding="13dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/headerText" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:id="@+id/multiChoiceDialogList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="14dp"
            android:paddingTop="14dp"
            android:paddingRight="14dp"
            android:paddingBottom="6dp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:id="@+id/multiChoiceCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/textSecondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/multiChoiceDone"
            android:layout_width="112dp"
            android:layout_height="48dp"
            android:background="@drawable/primary_button"
            android:text="@string/mixedApplySelection"
            android:textAllCaps="false"
            android:textColor="@color/headerText"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
